{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Information"
    }
  },
  "UseSqlite": true,
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=topzinto_erp.db"
  },
  "FileStorage": {
    "Provider": "Local",
    "LocalPath": "uploads"
  },
  "Backup": {
    "Enabled": false,
    "IntervalHours": 24,
    "RetentionCount": 5
  },
  "Redis": {
    "Enabled": false,
    "DefaultMinutes": 5
  },
  "App": {
    "BaseUrl": "http://localhost:5173"
  },
  "Email": {
    "Enabled": false,
    "SystemAlerts": true,
    "FromName": "TopZinto ERP",
    "FromAddress": "noreply@topzinto.com",
    "Smtp": {
      "Host": "smtp.example.com",
      "Port": 587,
      "UseSsl": true,
      "Username": "",
      "Password": ""
    }
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173", "http://localhost", "https://localhost"]
  },
  "Notifications": {
    "ScanIntervalHours": 6
  }
}
