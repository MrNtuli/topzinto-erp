FROM node:20-alpine AS build
WORKDIR /app

COPY src/Topzinto.Erp.Web/package.json src/Topzinto.Erp.Web/package-lock.json ./
RUN npm ci

COPY src/Topzinto.Erp.Web/ ./
RUN npm run build

FROM nginx:1.27-alpine
COPY deploy/nginx.conf /etc/nginx/conf.d/default.conf
COPY --from=build /app/dist /usr/share/nginx/html
EXPOSE 80
