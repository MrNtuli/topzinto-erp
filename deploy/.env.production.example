# Copy to project root as .env.production and fill in real values.
# Used by: docker compose -f docker-compose.yml -f docker-compose.prod.yml --env-file .env.production up -d

# Public URL (must match DNS and Caddyfile domain)
APP_DOMAIN=erp.example.co.za

# PostgreSQL
POSTGRES_PASSWORD=change-me-strong-password

# MinIO
MINIO_ROOT_USER=topzinto
MINIO_ROOT_PASSWORD=change-me-strong-password

# JWT signing key — at least 32 random characters
JWT_KEY=change-me-to-a-secure-random-key-at-least-32-chars

# Optional SMTP (set Email__Enabled=true to send mention emails)
Email__Enabled=false
Email__FromAddress=noreply@yourcompany.co.za
Email__Smtp__Host=smtp.yourprovider.com
Email__Smtp__Port=587
Email__Smtp__UseSsl=true
Email__Smtp__Username=
Email__Smtp__Password=
App__BaseUrl=https://erp.example.co.za
